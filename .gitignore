# Python build/cache output
__pycache__/
*.py[cod]
*.egg-info/
.pybuild/
.pytest_cache/
.venv/

# Default ATMCORE SDK
3rd/attemory-core*

# Native/CMake build output
build*/

# Wheel/package output
dist/
*.whl
package_testing/

