+import os
+import sys
+from collections import defaultdict
+
+import numpy as np
+
+
+ATTEMORY_SYSTEM_PROMPT = (
+    "Read the following conversations carefully and answer the query at the end."
+)
+ATTEMORY_ONESHOT_SYSTEM_PROMPT = (
+    "Read the following selected conversations carefully and find the most relavent conversations for the user's query."
+)
+ATTEMORY_ONESHOT_PRE_MEMORY_TEMPLATE = (
+    "The user's query: {question}. query's date/time: {question_date}.\n\n"
+    "Find conversations with direct evidence for the query. Focus on user-stated facts, "
+    "named entities, category inference, and usage evidence: people, places, services, "
+    "products, dates, times, events, activities, preferences, and outcomes. Use assistant "
+    "messages only as supporting evidence when they clarify user facts. For recent/latest/last "
+    "questions, prefer the newest direct evidence before the current date/time.\n\n"
+    "While reading, decide whether each conversation contains direct user evidence for the query, "
+    "not just a related topic.\n"
+)
+ATTEMORY_QUERY_CONTEXT_TEMPLATE = (
+    "**Read above selected conversation carefully and answer the user's query: {question}. query's date/time: {question_date}.\n\n"
+    "Find prior user-stated evidence that should guide a personalized answer to the query. "
+    "Focus on facts, preferences, constraints, named entities, places, dates, times, events, activities, possessions, services, products, "
+    "plans, outcomes, past experiences, relationships, and life-stage context. "
+    "For advice or recommendation queries, prefer conversations that reveal the user's relevant context, not only conversations that already contain advice. "
+    "Do not require exact keyword overlap: a relevant conversation may reveal evidence in the same personal domain, "
+    "such as current items, intended upgrades, old friends, school/work history, or meaningful memories. "
+    "Use assistant messages only as supporting evidence when they clarify user facts. "
+    "For recent/latest/last questions, prefer the newest direct evidence before the current date/time, which is {question_date}"
+)
+SESSION_HEADER_PREFIX = "**The following conversations take place at "
+SESSION_MIN_REMAINING_TOKENS = 5000
+EVAL_TOP_K = 50
+EVAL_K_VALUES = [1, 3, 5, 10, 30, 50]
+
+
+def get_attemory_num_processes():
+    return max(1, int(os.environ.get("ATTEMORY_WORKERS", "1")))
+
+
+def import_attemory_client():
+    attemory_root = os.environ.get(
+        "ATTEMORY_ROOT",
+        os.path.abspath(os.path.join(os.path.dirname(__file__), "../../../..")),
+    )
+    attemory_python_root = os.path.join(attemory_root, "python")
+    if os.path.isdir(attemory_python_root) and attemory_python_root not in sys.path:
+        sys.path.insert(0, attemory_python_root)
+    from attemory import AttemoryClient, AttemoryHTTPError, MemoryInput
+
+    return AttemoryClient, AttemoryHTTPError, MemoryInput
+
+
+def safe_session_id(value):
+    return "".join(ch if ch.isalnum() or ch in "._-" else "-" for ch in value)
+
+
+def search_result_id(result):
+    if result.id is None:
+        return None
+    try:
+        return int(result.id)
+    except ValueError:
+        return None
+
+
+def has_labeled_answer_turn(entry):
+    return any(
+        isinstance(turn, dict) and turn.get("has_answer")
+        for session in entry.get("haystack_sessions", [])
+        if isinstance(session, list)
+        for turn in session
+    )
+
+
+def should_average_attemory_metric(result, metric_granularity):
+    if "_abs" in result["question_id"]:
+        return False
+    if not has_labeled_answer_turn(result):
+        return False
+    if metric_granularity == "session":
+        return bool(result.get("answer_session_ids"))
+    if metric_granularity == "turn":
+        return True
+    return False
+
+
+def dcg(relevances, k):
+    relevances = np.asarray(relevances, dtype=float)[:k]
+    if relevances.size == 0:
+        return 0.0
+    return relevances[0] + np.sum(
+        relevances[1:] / np.log2(np.arange(2, relevances.size + 1))
+    )
+
+
+def evaluate_doc_retrieval(rankings, correct_docs, corpus_ids, k):
+    correct_docs = set(correct_docs)
+    recalled_docs = {corpus_ids[idx] for idx in rankings[:k]}
+    recall_any = float(any(doc in recalled_docs for doc in correct_docs))
+    recall_all = float(bool(correct_docs) and all(doc in recalled_docs for doc in correct_docs))
+    relevances = [1 if corpus_ids[idx] in correct_docs else 0 for idx in rankings[:k]]
+    ideal_relevances = [1] * min(len(correct_docs), k)
+    ideal_dcg = dcg(ideal_relevances, k)
+    ndcg_any = 0.0 if ideal_dcg == 0 else dcg(relevances, k) / ideal_dcg
+    return recall_any, recall_all, ndcg_any
+
+
+def evaluate_session_retrieval(rankings, correct_sessions, session_ids, k):
+    # Session recall is computed on de-duplicated session ids. Multiple turns from
+    # the same session should only occupy one session-ranking slot.
+    seen = set()
+    ranked_sessions = []
+    for idx in rankings:
+        session_id = session_ids[idx]
+        if session_id not in seen:
+            seen.add(session_id)
+            ranked_sessions.append(session_id)
+        if len(ranked_sessions) >= k:
+            break
+
+    correct_sessions = set(correct_sessions)
+    recalled_sessions = set(ranked_sessions[:k])
+    recall_any = float(any(session in recalled_sessions for session in correct_sessions))
+    recall_all = float(
+        bool(correct_sessions) and all(session in recalled_sessions for session in correct_sessions)
+    )
+    relevances = [1 if session in correct_sessions else 0 for session in ranked_sessions[:k]]
+    ideal_relevances = [1] * min(len(correct_sessions), k)
+    ideal_dcg = dcg(ideal_relevances, k)
+    ndcg_any = 0.0 if ideal_dcg == 0 else dcg(relevances, k) / ideal_dcg
+    return recall_any, recall_all, ndcg_any
+
+
+class AttemoryRetrievalMaster:
+    def __init__(self, args):
+        self.args = args
+        if self.args.granularity != "session":
+            raise NotImplementedError("attemory only supports session granularity")
+
+        AttemoryClient, AttemoryHTTPError, MemoryInput = import_attemory_client()
+        self.AttemoryHTTPError = AttemoryHTTPError
+        self.MemoryInput = MemoryInput
+        self.client = AttemoryClient(
+            host=os.environ.get("ATTEMORY_HOST", "127.0.0.1"),
+            port=int(os.environ.get("ATTEMORY_PORT", "9006")),
+            timeout=float(os.environ.get("ATTEMORY_TIMEOUT", "3600")),
+        )
+
+        self.use_query_context = os.environ.get("ATTEMORY_QUERY_CONTEXT", "1") != "0"
+        self.live_metrics = os.environ.get("ATTEMORY_LIVE_METRICS", "1") != "0"
+        self.report_every = max(1, int(os.environ.get("ATTEMORY_REPORT_EVERY", "1")))
+        self.seen_questions = 0
+        self.skipped_questions = 0
+        self.metric_sums = defaultdict(lambda: defaultdict(float))
+        self.metric_counts = defaultdict(lambda: defaultdict(int))
+
+    def run_session_entry(self, entry):
+        # Some LongMemEval entries do not contain any turn with has_answer=True.
+        # They are excluded from the reported metric, so skip them before
+        # creating an Attemory session and running search.
+        if not has_labeled_answer_turn(entry):
+            return self.skipped_result(entry)
+
+        # LongMemEval gives each question a haystack of dated sessions. For Attemory
+        # we keep the original session structure:
+        #
+        #   session date header
+        #   <user>: ...
+        #   <assistant>: ...
+        #
+        # Each dialogue turn is indexed as one memory. Headers are also added to
+        # give the model time context, but headers have no search id and are not
+        # counted as retrieved evidence.
+        corpus, corpus_ids, session_ids, timestamps = [], [], [], []
+        for session_id, session, timestamp in zip(
+            entry["haystack_session_ids"],
+            entry["haystack_sessions"],
+            entry["haystack_dates"],
+        ):
+            self.add_header(corpus, corpus_ids, session_ids, timestamps, session_id, timestamp)
+            for turn_id, turn in enumerate(session):
+                corpus.append("<{}>: {}".format(turn["role"], turn["content"]))
+                corpus_ids.append(self.content_id(session_id, turn_id, turn))
+                session_ids.append(session_id)
+                timestamps.append(timestamp)
+
+        return self.run_entry(entry, corpus, corpus_ids, session_ids, timestamps)
+
+    def run_entry(self, entry, corpus, corpus_ids, session_ids, timestamps):
+        query = self.format_query(entry["question"])
+        rankings = self.run_retrieval(entry, query, corpus, timestamps, session_ids)
+        correct_docs = list({doc_id for doc_id in corpus_ids if "answer" in doc_id})
+        correct_sessions = entry["answer_session_ids"]
+
+        result = {
+            "question_id": entry["question_id"],
+            "question_type": entry["question_type"],
+            "question": entry["question"],
+            "answer": entry["answer"],
+            "question_date": entry["question_date"],
+            "haystack_dates": entry["haystack_dates"],
+            "haystack_sessions": entry["haystack_sessions"],
+            "haystack_session_ids": entry["haystack_session_ids"],
+            "answer_session_ids": entry["answer_session_ids"],
+            "retrieval_results": {
+                "query": query,
+                "ranked_items": [
+                    {
+                        "corpus_id": corpus_ids[idx],
+                        "session_id": session_ids[idx],
+                        "text": corpus[idx],
+                        "timestamp": timestamps[idx],
+                    }
+                    for idx in rankings
+                ],
+                "metrics": {
+                    "session": {},
+                    "turn": {},
+                },
+            },
+        }
+
+        for k in EVAL_K_VALUES:
+            recall_any, recall_all, ndcg_any = evaluate_doc_retrieval(
+                rankings,
+                correct_docs,
+                corpus_ids,
+                k,
+            )
+            result["retrieval_results"]["metrics"]["turn"].update({
+                "recall_any@{}".format(k): recall_any,
+                "recall_all@{}".format(k): recall_all,
+                "ndcg_any@{}".format(k): ndcg_any,
+            })
+
+            recall_any, recall_all, ndcg_any = evaluate_session_retrieval(
+                rankings,
+                correct_sessions,
+                session_ids,
+                k,
+            )
+            result["retrieval_results"]["metrics"]["session"].update({
+                "recall_any@{}".format(k): recall_any,
+                "recall_all@{}".format(k): recall_all,
+                "ndcg_any@{}".format(k): ndcg_any,
+            })
+
+        return result
+
+    def skipped_result(self, entry):
+        query = self.format_query(entry["question"])
+        result = {
+            "question_id": entry["question_id"],
+            "question_type": entry["question_type"],
+            "question": entry["question"],
+            "answer": entry["answer"],
+            "question_date": entry["question_date"],
+            "haystack_dates": entry["haystack_dates"],
+            "haystack_sessions": entry["haystack_sessions"],
+            "haystack_session_ids": entry["haystack_session_ids"],
+            "answer_session_ids": entry["answer_session_ids"],
+            "retrieval_results": {
+                "query": query,
+                "ranked_items": [],
+                "metrics": {
+                    "session": {},
+                    "turn": {},
+                },
+            },
+        }
+        for k in EVAL_K_VALUES:
+            for granularity in ["session", "turn"]:
+                result["retrieval_results"]["metrics"][granularity].update({
+                    "recall_any@{}".format(k): 0.0,
+                    "recall_all@{}".format(k): 0.0,
+                    "ndcg_any@{}".format(k): 0.0,
+                })
+        return result
+
+    def run_retrieval(self, entry, query, corpus, timestamps, session_ids):
+        session_name = safe_session_id(
+            "lme-{}-{}".format(entry["question_id"], self.args.granularity)
+        )
+        session_client = self.client.with_session(session_name)
+        self.delete_session_if_exists(session_client)
+
+        try:
+            # Step 1. Build a fresh Attemory session for this one question.
+            #
+            # LongMemEval has one query per sample, so there is no need to persist
+            # and reuse a session across questions. Rebuilding keeps the script
+            # simple and makes each sample independent.
+            session_client.create_session()
+            output = session_client.add_system(ATTEMORY_SYSTEM_PROMPT)
+            remaining_tokens = output.remaining_tokens
+
+            # Step 2. Record the original order of sessions and turns.
+            #
+            # Search returns memory ids. We use corpus indices as memory ids, so
+            # an Attemory result id can be mapped directly back to corpus[idx].
+            # The session layout is also reused for the optional one-shot pass:
+            # selected turns are placed back under their original session header
+            # and kept in chronological order within that session.
+            session_order = []
+            session_header_index = {}
+            session_turn_indices = defaultdict(list)
+            item_session_ids = {}
+            seen_sessions = set()
+            for idx, (text, session_id) in enumerate(zip(corpus, session_ids)):
+                if session_id not in seen_sessions:
+                    seen_sessions.add(session_id)
+                    session_order.append(session_id)
+                if text.startswith(SESSION_HEADER_PREFIX):
+                    session_header_index[session_id] = idx
+                else:
+                    session_turn_indices[session_id].append(idx)
+                    item_session_ids[idx] = session_id
+
+            # Step 3. Add memories to Attemory.
+            #
+            # Headers are added without ids, because they are context only.
+            # Dialogue turns are added with id=str(corpus_index), because those
+            # are the retrievable units used by the benchmark metrics.
+            for session_id in session_order:
+                if remaining_tokens < SESSION_MIN_REMAINING_TOKENS:
+                    session_client.next_segment()
+
+                header_idx = session_header_index.get(session_id)
+                if header_idx is not None:
+                    output = session_client.add_memory(
+                        self.MemoryInput(text=corpus[header_idx])
+                    )
+                    remaining_tokens = output.remaining_tokens
+
+                for idx in session_turn_indices[session_id]:
+                    output = session_client.add_memory(
+                        self.MemoryInput(id=str(idx), text=corpus[idx])
+                    )
+                    remaining_tokens = output.remaining_tokens
+
+            session_client.index_session()
+
+            # Step 4. Run the normal Attemory search.
+            query_context = self.format_query_context(query, entry["question_date"])
+            candidates = session_client.search(query, query_context=query_context)
+
+            ranked_ids = []
+            seen_ids = set()
+            candidate_segments = set()
+            for result in candidates:
+                if result.segment_id is not None:
+                    candidate_segments.add(result.segment_id)
+                idx = search_result_id(result)
+                if idx is not None and idx not in seen_ids:
+                    seen_ids.add(idx)
+                    ranked_ids.append(idx)
+
+            # Step 5. If search results span multiple segments, run one-shot
+            # search on the selected turns only.
+            #
+            # The one-shot input is still organized as conversations:
+            #
+            #   one-shot instruction memory
+            #   original session header
+            #   selected turn from that session
+            #   selected turn from that session
+            #   ...
+            #
+            # This makes the reranking input close to what the model saw during
+            # indexing, while avoiding unrelated turns from sessions that were
+            # not returned by the first search.
+            reranked_results = None
+            if ranked_ids and len(candidate_segments) > 1:
+                ids_for_this_round = ranked_ids
+                for _ in range(2):
+                    selected_ids_by_session = defaultdict(set)
+                    for idx in ids_for_this_round:
+                        session_id = item_session_ids.get(idx)
+                        if session_id is not None:
+                            selected_ids_by_session[session_id].add(idx)
+
+                    if not selected_ids_by_session:
+                        break
+
+                    oneshot_memories = [
+                        self.MemoryInput(text=self.format_oneshot_pre_memory(entry))
+                    ]
+                    for session_id in session_order:
+                        selected_ids = selected_ids_by_session.get(session_id)
+                        if not selected_ids:
+                            continue
+
+                        header_idx = session_header_index.get(session_id)
+                        if header_idx is not None:
+                            oneshot_memories.append(
+                                self.MemoryInput(text=corpus[header_idx])
+                            )
+
+                        for idx in session_turn_indices[session_id]:
+                            if idx in selected_ids:
+                                oneshot_memories.append(
+                                    self.MemoryInput(id=str(idx), text=corpus[idx])
+                                )
+
+                    non_id_count = sum(
+                        1 for memory in oneshot_memories if memory.id is None
+                    )
+                    oneshot_top_k = min(len(oneshot_memories), non_id_count + EVAL_TOP_K)
+                    reranked_results = session_client.oneshot_search(
+                        query,
+                        oneshot_memories,
+                        system=ATTEMORY_ONESHOT_SYSTEM_PROMPT,
+                        query_context=query_context,
+                        top_k=oneshot_top_k,
+                    )
+
+                    reranked_segments = {
+                        result.segment_id
+                        for result in reranked_results
+                        if result.segment_id is not None
+                    }
+                    if len(reranked_segments) <= 1:
+                        break
+
+                    ids_for_this_round = []
+                    seen_round_ids = set()
+                    for result in reranked_results:
+                        idx = search_result_id(result)
+                        if idx is not None and idx not in seen_round_ids:
+                            seen_round_ids.add(idx)
+                            ids_for_this_round.append(idx)
+
+            # Step 6. Merge the optional one-shot order with the original search
+            # order. The one-shot result is used as the front of the final ranking,
+            # and any search result not returned by one-shot is appended afterward.
+            if reranked_results is not None:
+                merged_ids = []
+                seen_merged_ids = set()
+                for result in reranked_results:
+                    idx = search_result_id(result)
+                    if idx is not None and idx not in seen_merged_ids:
+                        seen_merged_ids.add(idx)
+                        merged_ids.append(idx)
+                for idx in ranked_ids:
+                    if idx not in seen_merged_ids:
+                        seen_merged_ids.add(idx)
+                        merged_ids.append(idx)
+                ranked_ids = merged_ids
+
+            # Step 7. The official evaluator expects a complete permutation over
+            # the corpus. Attemory only returns the memories it ranked, so append
+            # any unseen corpus item at the end.
+            final_rankings = []
+            seen_final_ids = set()
+            for idx in ranked_ids:
+                if 0 <= idx < len(corpus) and idx not in seen_final_ids:
+                    seen_final_ids.add(idx)
+                    final_rankings.append(idx)
+            for idx in range(len(corpus)):
+                if idx not in seen_final_ids:
+                    final_rankings.append(idx)
+
+            return np.asarray(final_rankings, dtype=np.int64)
+        finally:
+            self.delete_session_if_exists(session_client)
+
+    def delete_session_if_exists(self, session_client):
+        try:
+            session_client.delete_session()
+        except self.AttemoryHTTPError as exc:
+            if exc.status_code != 404:
+                raise
+
+    def report_result(self, result):
+        if not self.live_metrics:
+            return
+
+        self.seen_questions += 1
+        reported_any = False
+        for granularity, metrics in result["retrieval_results"]["metrics"].items():
+            if not should_average_attemory_metric(result, granularity):
+                continue
+            reported_any = True
+            for name, value in metrics.items():
+                if name.startswith("recall_"):
+                    self.metric_sums[granularity][name] += value
+                    self.metric_counts[granularity][name] += 1
+
+        if not reported_any:
+            self.skipped_questions += 1
+            print(
+                "[attemory] live processed={} skipped qid={} valid={} skipped={}".format(
+                    self.seen_questions,
+                    result["question_id"],
+                    self.seen_questions - self.skipped_questions,
+                    self.skipped_questions,
+                ),
+                flush=True,
+            )
+            return
+
+        if self.seen_questions % self.report_every == 0:
+            print(self.live_metrics_line(result["question_id"]), flush=True)
+
+    def live_metrics_line(self, question_id):
+        valid = self.seen_questions - self.skipped_questions
+        parts = [
+            "[attemory] live processed={} qid={} valid={} skipped={}".format(
+                self.seen_questions,
+                question_id,
+                valid,
+                self.skipped_questions,
+            )
+        ]
+        for granularity in ["session", "turn"]:
+            metrics = self.metric_sums.get(granularity, {})
+            names = [
+                name
+                for name in [
+                    "recall_any@1",
+                    "recall_any@3",
+                    "recall_any@5",
+                    "recall_any@10",
+                    "recall_any@30",
+                    "recall_any@50",
+                    "recall_all@1",
+                    "recall_all@3",
+                    "recall_all@5",
+                    "recall_all@10",
+                    "recall_all@30",
+                    "recall_all@50",
+                ]
+                if name in metrics
+            ]
+            if not names:
+                continue
+            values = []
+            for name in names:
+                count = self.metric_counts[granularity][name]
+                total = metrics[name]
+                values.append("{}={:.4f}({:.0f}/{})".format(name, total / count, total, count))
+            parts.append("{}: {}".format(granularity, " ".join(values)))
+        return " | ".join(parts)
+
+    def add_header(self, corpus, corpus_ids, session_ids, timestamps, session_id, timestamp):
+        corpus.append(self.format_session_header(timestamp))
+        corpus_ids.append(self.header_id(session_id))
+        session_ids.append(session_id)
+        timestamps.append(timestamp)
+
+    @staticmethod
+    def header_id(session_id):
+        corpus_id = "{}_header".format(session_id)
+        if "answer" in session_id:
+            return corpus_id.replace("answer", "noans")
+        return corpus_id
+
+    @staticmethod
+    def content_id(session_id, turn_id, turn):
