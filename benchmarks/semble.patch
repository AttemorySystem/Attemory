+def file_rank(file_paths: list[str], target_path: str) -> int | None:
+    for index, file_path in enumerate(file_paths, 1):
+        if path_matches(file_path, target_path):
+            return index
+    return None
+
+
+def _session_id(repo: str) -> str:
+    return f"attemory-semble-{repo}"
+
+
+def _file_header(file_path: str) -> str:
+    return f"{FILE_HEADER_PREFIX}{file_path}"
+
+
+def _read_text(path: Path) -> str:
+    return path.read_text(encoding="utf-8", errors="replace")
+
+
+def _list_code_files(repo_root: Path) -> list[Path]:
+    files: list[Path] = []
+    for root, dirnames, filenames in os.walk(repo_root):
+        dirnames[:] = sorted(dirname for dirname in dirnames if dirname not in SKIP_DIRS)
+        root_path = Path(root)
+        for filename in sorted(filenames):
+            path = root_path / filename
+            if path.suffix.lower() in DEFAULT_CODE_SUFFIXES or path.name in SPECIAL_CODE_FILENAMES:
+                files.append(path)
+    return sorted(files, key=lambda path: path.relative_to(repo_root).as_posix())
+
+
+def _build_chunks(repo_root: Path) -> tuple[list[CodeChunk], int, int]:
+    chunks: list[CodeChunk] = []
+    total_lines = 0
+    code_files = _list_code_files(repo_root)
+    for path in code_files:
+        rel_path = path.relative_to(repo_root).as_posix()
+        lines = _read_text(path).splitlines(keepends=True)
+        if not lines:
+            continue
+        total_lines += len(lines)
+        for start, end in _collect_line_blocks(lines):
+            text = "".join(lines[start - 1 : end])
+            if text.strip():
+                chunks.append(
+                    CodeChunk(
+                        id=str(len(chunks)),
+                        file=rel_path,
+                        start_line=start,
+                        end_line=end,
+                        text=text,
+                    )
+                )
+    return chunks, len(code_files), total_lines
+
+
+def _collect_line_blocks(
+    lines: list[str],
+    *,
+    target_lines: int = TARGET_LINES_PER_BLOCK,
+    split_window: int = BLANK_LINE_SEARCH_WINDOW,
+) -> list[tuple[int, int]]:
+    total_lines = len(lines)
+    if total_lines == 0:
+        return []
+
+    blocks: list[tuple[int, int]] = []
+    start = 1
+    while start <= total_lines:
+        preferred_end = min(start + target_lines - 1, total_lines)
+        if preferred_end == total_lines:
+            blocks.append((start, total_lines))
+            break
+
+        search_start = max(start, preferred_end - split_window)
+        search_end = min(total_lines, preferred_end + split_window)
+        blank_candidates = [
+            line_no
+            for line_no in range(search_start, search_end + 1)
+            if not lines[line_no - 1].strip()
+        ]
+        if blank_candidates:
+            end = min(blank_candidates, key=lambda line_no: (abs(line_no - preferred_end), line_no))
+        else:
+            end = preferred_end
+
+        blocks.append((start, end))
+        start = end + 1
+
+    return blocks
+
+
+def _write_index_files(
+    *,
+    index_dir: Path,
+    session_id: str,
+    repo_root: Path,
+    chunks: list[CodeChunk],
+    file_count: int,
+    line_count: int,
+) -> dict[str, ChunkLocation]:
+    index_dir.mkdir(parents=True, exist_ok=True)
+    memory_map = {chunk.id: ChunkLocation(file=chunk.file, lines=chunk.lines) for chunk in chunks}
+    with (index_dir / MAP_FILE).open("w", encoding="utf-8") as handle:
+        for chunk in chunks:
+            handle.write(
+                json.dumps(
+                    {
+                        "id": chunk.id,
+                        "file": chunk.file,
+                        "lines": chunk.lines,
+                    },
+                    ensure_ascii=False,
+                )
+                + "\n"
+            )
+
+    metadata = {
+        "session_id": session_id,
+        "repo_root": str(repo_root),
+        "map_file": MAP_FILE,
+        "memory_count": len(chunks),
+        "file_count": file_count,
+        "line_count": line_count,
+        "system_prompt": SEARCH_SYSTEM_PROMPT,
+    }
+    (index_dir / INDEX_FILE).write_text(json.dumps(metadata, indent=2) + "\n", encoding="utf-8")
+    return memory_map
+
+
+def _read_index_files(index_dir: Path) -> IndexResult | None:
+    index_path = index_dir / INDEX_FILE
+    map_path = index_dir / MAP_FILE
+    if not index_path.exists() or not map_path.exists():
+        return None
+
+    try:
+        metadata = json.loads(index_path.read_text(encoding="utf-8"))
+        session_id = str(metadata["session_id"])
+        repo_root = Path(str(metadata["repo_root"]))
+        memory_count = int(metadata["memory_count"])
+        memory_map: dict[str, ChunkLocation] = {}
+        with map_path.open("r", encoding="utf-8") as handle:
+            for line in handle:
+                if not line.strip():
+                    continue
+                item = json.loads(line)
+                memory_map[str(item["id"])] = ChunkLocation(file=str(item["file"]), lines=str(item["lines"]))
+    except (OSError, KeyError, TypeError, ValueError, json.JSONDecodeError) as exc:
+        print(f"Cannot reuse {index_dir}: invalid index files: {exc}", file=sys.stderr)
+        return None
+
+    if len(memory_map) != memory_count:
+        print(
+            f"Cannot reuse {index_dir}: map has {len(memory_map)} memories, metadata says {memory_count}.",
+            file=sys.stderr,
+        )
+        return None
+
+    return IndexResult(
+        index_dir=index_dir,
+        session_id=session_id,
+        repo_root=repo_root,
+        index_ms=0.0,
+        memory_count=memory_count,
+        reused=True,
+        memory_map=memory_map,
+    )
+
+
+def _delete_session(client: Any, session_id: str) -> None:
+    try:
+        client.delete_session(session_id=session_id)
+    except OSError:
+        raise SystemExit(f"Could not connect to attemory at {client.host}:{client.port}; start the server first.")
+    except Exception:
+        pass
+
+
+def _fresh_index(
+    *,
+    repo: str,
+    benchmark_dir: Path,
+    index_root: Path,
+    client: Any,
+) -> IndexResult:
+    session_id = _session_id(repo)
+    index_dir = index_root / repo
+    _delete_session(client, session_id)
+
+    started = time.perf_counter()
+    chunks, file_count, line_count = _build_chunks(benchmark_dir)
+    session_client = client.with_session(session_id)
+    session_client.create_session()
+    output = session_client.add_system(SEARCH_SYSTEM_PROMPT)
+    remaining_tokens = output.remaining_tokens
+    current_file: str | None = None
+    for chunk in chunks:
+        if chunk.file != current_file:
+            if remaining_tokens < FILE_MIN_REMAINING_TOKENS:
+                session_client.next_segment()
+            output = session_client.add_memory(_file_header(chunk.file))
+            remaining_tokens = output.remaining_tokens
+            current_file = chunk.file
+        output = session_client.add_memory(chunk.memory_text, id=chunk.id)
+        remaining_tokens = output.remaining_tokens
+    session_client.index_session()
+    session_client.save_session()
+    memory_map = _write_index_files(
+        index_dir=index_dir,
+        session_id=session_id,
+        repo_root=benchmark_dir,
+        chunks=chunks,
+        file_count=file_count,
+        line_count=line_count,
+    )
+    index_ms = (time.perf_counter() - started) * 1000
+    return IndexResult(
+        index_dir=index_dir,
+        session_id=session_id,
+        repo_root=benchmark_dir,
+        index_ms=index_ms,
+        memory_count=len(chunks),
+        reused=False,
+        memory_map=memory_map,
+    )
+
+
+def _build_or_restore_index(
+    *,
+    repo: str,
+    benchmark_dir: Path,
+    index_root: Path,
+    client: Any,
+    reuse_index: bool,
+) -> IndexResult:
+    if reuse_index:
+        cached = _read_index_files(index_root / repo)
+        if cached is not None:
+            return cached
+        print(f"Reindexing {repo}: reusable index artifacts were not found.", file=sys.stderr)
+    return _fresh_index(
+        repo=repo,
+        benchmark_dir=benchmark_dir,
+        index_root=index_root,
+        client=client,
+    )
+
