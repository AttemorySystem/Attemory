+        if current_file != chunk.file:
+            if usage.remaining_tokens < MIN_REMAINING_TOKENS:
+                session.next_segment()
+            usage = session.add_memory(_file_header(chunk.file))
+            if usage.remaining_tokens < MIN_REMAINING_TOKENS:
+                session.next_segment()
+            current_file = chunk.file
+        usage = session.add_memory({"id": chunk.id, "text": chunk.memory_text})
+        if usage.remaining_tokens < MIN_REMAINING_TOKENS:
+            session.next_segment()
+
+    session.index_session()
+    session.save_session()
+    index_ms = (time.perf_counter() - start) * 1000
+
+    index_dir.mkdir(parents=True, exist_ok=True)
+    (index_dir / INDEX_FILE).write_text(
+        json.dumps(
+            {
+                "repo_name": repo_name,
+                "repo_root": str(repo_root),
+                "repo_fingerprint": fingerprint,
+                "session_id": session_id,
+                "chunk_lines": chunk_lines,
+                "blank_window": blank_window,
+                "context_structure": CONTEXT_STRUCTURE,
+                "file_header_prefix": FILE_HEADER_PREFIX,
+                "kv_persist": True,
+                "system_prompt": SEARCH_SYSTEM_PROMPT,
+                "memory_count": len(memory_map),
+                "created_at": int(time.time()),
+            },
+            indent=2,
+            sort_keys=True,
+        )
+    )
+    with (index_dir / MAP_FILE).open("w", encoding="utf-8") as f:
+        for memory_id, location in memory_map.items():
+            f.write(json.dumps({"id": memory_id, **asdict(location)}, ensure_ascii=False) + "\n")
+
+    return IndexResult(
+        index_dir=index_dir,
+        session_id=session_id,
+        repo_name=repo_name,
+        repo_root=repo_root,
+        repo_fingerprint=fingerprint,
+        index_ms=index_ms,
+        memory_count=len(memory_map),
+        reused=False,
+        memory_map=memory_map,
+    )
+
+
+def build_chunks(
+    repo_root: str | Path,
+    *,
+    chunk_lines: int = TARGET_LINES_PER_BLOCK,
+    blank_window: int = BLANK_LINE_SEARCH_WINDOW,
+) -> list[CodeChunk]:
+    repo_root = Path(repo_root).resolve()
+    chunks: list[CodeChunk] = []
+    for file_path in list_code_files(repo_root):
+        rel_path = file_path.relative_to(repo_root).as_posix()
+        try:
+            text = file_path.read_text(errors="ignore")
+        except OSError:
+            continue
+        lines = text.splitlines()
+        for start_line, end_line in _line_blocks(lines, chunk_lines=chunk_lines, blank_window=blank_window):
+            block = "\n".join(lines[start_line - 1 : end_line])
+            if not block.strip():
+                continue
+            chunks.append(
+                CodeChunk(
+                    id=_chunk_id(rel_path, start_line, end_line),
+                    file=rel_path,
+                    start_line=start_line,
+                    end_line=end_line,
+                    text=block,
+                )
+            )
+    return chunks
+
+
+def list_code_files(repo_root: str | Path) -> list[Path]:
+    repo_root = Path(repo_root).resolve()
+    files: list[Path] = []
+    for root, dirnames, filenames in os.walk(repo_root):
+        dirnames[:] = sorted(dirname for dirname in dirnames if dirname not in SKIP_DIRS)
+        root_path = Path(root)
+        for filename in sorted(filenames):
+            path = root_path / filename
+            if _is_code_file(path):
+                files.append(path)
+    return files
+
+
+def repo_fingerprint(repo_root: str | Path) -> str:
+    repo_root = Path(repo_root).resolve()
+    result = subprocess.run(
+        ["git", "-C", str(repo_root), "rev-parse", "HEAD"],
+        text=True,
+        capture_output=True,
+        check=False,
+    )
+    if result.returncode == 0 and result.stdout.strip():
+        return result.stdout.strip()[:12]
+
+    digest = hashlib.sha1()
+    for path in list_code_files(repo_root):
+        stat = path.stat()
+        digest.update(path.relative_to(repo_root).as_posix().encode())
+        digest.update(str(stat.st_mtime_ns).encode())
+        digest.update(str(stat.st_size).encode())
+    return f"nogit-{digest.hexdigest()[:12]}"
+
+
+def session_id_for_repo(repo_name: str, fingerprint: str) -> str:
+    raw = f"attemory-sweqa-{repo_name}-{fingerprint}"
+    return "".join(char if char.isalnum() or char in "-_" else "-" for char in raw)
+
+
+def _line_blocks(lines: list[str], *, chunk_lines: int, blank_window: int) -> list[tuple[int, int]]:
+    blocks: list[tuple[int, int]] = []
+    start = 1
+    total = len(lines)
+    while start <= total:
+        end = min(total, start + chunk_lines - 1)
+        if end < total:
+            search_to = min(total, end + blank_window)
+            for candidate in range(end, search_to + 1):
+                if not lines[candidate - 1].strip():
+                    end = candidate
+                    break
+        blocks.append((start, end))
+        start = end + 1
+    return blocks
+
+
+def _is_code_file(path: Path) -> bool:
+    return path.name in SPECIAL_CODE_FILENAMES or path.suffix.lower() in DEFAULT_CODE_SUFFIXES
+
+
+def _chunk_id(file_path: str, start_line: int, end_line: int) -> str:
+    digest = hashlib.sha1(f"{file_path}:{start_line}:{end_line}".encode()).hexdigest()[:12]
+    return f"{digest}:{file_path}:{start_line}-{end_line}"
+
+
+def _file_header(file_path: str) -> str:
+    return f"{FILE_HEADER_PREFIX}{file_path}"
+
+
+def _read_memory_map(path: Path) -> dict[str, ChunkLocation]:
+    memory_map: dict[str, ChunkLocation] = {}
+    with path.open(encoding="utf-8") as f:
+        for line in f:
+            if not line.strip():
+                continue
+            row = json.loads(line)
+            memory_id = row.pop("id")
+            if "start_line" not in row or "end_line" not in row:
+                start, end = str(row["lines"]).split("-", 1)
+                row["start_line"] = int(start)
+                row["end_line"] = int(end)
+            memory_map[memory_id] = ChunkLocation(
+                file=row["file"],
+                start_line=int(row["start_line"]),
+                end_line=int(row["end_line"]),
+            )
+    return memory_map
