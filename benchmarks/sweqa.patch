+The following files and line ranges are semantic-search candidate evidence from the repository.
+Inspect these locations first. Use them as a shortcut to relevant code, not as a complete answer scope.
+
+If the listed ranges contain the named symbols/classes/functions and enough surrounding code or tests to answer the question, answer from that evidence directly.
+If an important symbol, file, caller, test, exception path, or dataflow mentioned in the question is missing from these results, run a narrow repository search for that missing
+item and read only the smallest surrounding ranges needed.
+
+Do not broaden exploration just because semantic search results are provided; broaden only to fill a concrete evidence gap.
+
+For questions that require checking multiple files, call chains, exception propagation, redirect/auth/cookie/session behavior, lifecycle reasoning, or dataflow across components,
+prefer using a subagent to inspect the listed candidate ranges and any narrowly missing evidence. Ask the subagent to verify whether the evidence covers the components named
+in the question, and to return a concise evidence summary with file paths, functions/classes, line numbers, and any specific unresolved gap.
+
+Do not serially read broad evidence in the main context when a focused subagent can verify the candidate locations and missing links.
+
+{search_text}
+</semantic_search_results>
+"""
+
+def prepare_prompts(
+    *,
+    backend: str,
+    repo: str,
+    run_dir: Path,
+    benchmark_dir: Path | None = None,
+    repos_root: Path | None = None,
+    index_root: Path | None = None,
+    sample_ids: list[str] | None = None,
+) -> None:
+    benchmark_dir = benchmark_dir or Path(os.environ.get("BENCHMARK_DIR") or str(DEFAULT_BENCH_ROOT / "Benchmark"))
+    if repos_root is None:
+        repos_root = Path(os.environ["REPOS_ROOT"]) if os.environ.get("REPOS_ROOT") else _default_repos_root(repo)
+    index_root = index_root or Path(os.environ.get("ATTEMORY_INDEX_ROOT") or str(DEFAULT_INDEX_ROOT))
+
+    repo_root = repos_root / repo
+    benchmark_file = benchmark_dir / f"{repo}.jsonl"
+    run_dir.mkdir(parents=True, exist_ok=True)
+    (run_dir / "repo_root.txt").write_text(str(repo_root), encoding="utf-8")
+
+    wanted = set(sample_ids or [])
+    sample_ids: list[str] = []
+    for index, row in enumerate(_read_jsonl(benchmark_file)):
+        question = str(row.get("question") or row.get("problem_statement") or "")
+        reference = str(row.get("answer") or row.get("reference_answer") or "")
+        current_sample_id = str(row.get("id") or row.get("sample_id") or _stable_id(repo, index, question))
+        if wanted and current_sample_id not in wanted:
+            continue
+        sample_ids.append(current_sample_id)
+
+        sample_dir = run_dir / current_sample_id
+        sample_dir.mkdir(parents=True, exist_ok=True)
+        (sample_dir / "sample.json").write_text(
+            json.dumps(
+                {
+                    "sample_id": current_sample_id,
+                    "repo": repo,
+                    "question": question,
+                    "reference_answer": reference,
+                    "raw": row,
+                },
+                ensure_ascii=False,
+            )
+            + "\n",
+            encoding="utf-8",
+        )
+
+        search_text = ""
+        if backend == "attemory":
+            search_text = _search_attemory(
+                question=question,
+                repo=repo,
+                repo_root=repo_root,
+                index_root=index_root,
+                traj=sample_dir / "attemory_search.jsonl",
+            )
+            (sample_dir / "attemory_search.txt").write_text(search_text, encoding="utf-8")
+
+        semantic_block = SEARCH_BLOCK.format(search_text=search_text).rstrip() + "\n" if search_text else ""
+        (sample_dir / "prompt.txt").write_text(
+            PROMPT.format(repo_root=repo_root, question=question, semantic_search_block=semantic_block),
+            encoding="utf-8",
+        )
+
+    missing = sorted(wanted.difference(sample_ids))
+    if missing:
+        raise ValueError(f"sample not found: {', '.join(missing)}")
+    (run_dir / "samples.txt").write_text("\n".join(sample_ids) + "\n", encoding="utf-8")
+
+
+def _read_jsonl(path: Path):
+    with path.open(encoding="utf-8") as f:
+        for line in f:
+            if line.strip():
+                yield json.loads(line)
+
+
+def _stable_id(repo: str, index: int, question: str) -> str:
+    digest = hashlib.sha1(question.encode("utf-8")).hexdigest()[:10]
+    return f"{repo}-{index:03d}-{digest}"
+
+
+def _default_repos_root(repo_name: str) -> Path:
+    if (DEFAULT_REPOS_ROOT / repo_name).exists():
+        return DEFAULT_REPOS_ROOT
+    if (FALLBACK_REPOS_ROOT / repo_name).exists():
+        return FALLBACK_REPOS_ROOT
+    return DEFAULT_REPOS_ROOT
+
+
+def _search_attemory(*, question: str, repo: str, repo_root: Path, index_root: Path, traj: Path) -> str:
+    start = time.perf_counter()
+    client = make_attemory_client(
+        host=os.environ.get("ATTEMORY_HOST", "127.0.0.1"),
+        port=int(os.environ.get("ATTEMORY_PORT", "9006")),
+        timeout=float(os.environ.get("ATTEMORY_TIMEOUT", "3600")),
+    )
+    index = restore_index(client=client, repo_name=repo, repo_root=repo_root, index_root=index_root)
+    search_result = retrieve_hits(
+        client=client,
+        session_id=index.session_id,
+        question=question,
+        memory_map=index.memory_map,
+        top_k=int(os.environ.get("ATTEMORY_SEARCH_TOPK", "8")),
+        chunk_top_k=int(os.environ.get("ATTEMORY_CHUNK_TOPK", "16")),
+    )
+    record: dict[str, Any] = {
+        "ok": True,
+        "query": question,
+        "repo_name": repo,
+        "repo_root": str(repo_root),
+        "top_k": int(os.environ.get("ATTEMORY_SEARCH_TOPK", "8")),
+        "elapsed_ms": (time.perf_counter() - start) * 1000,
+        "index": {
+            "session_id": index.session_id,
+            "reused": index.reused,
+            "index_ms": index.index_ms,
+            "memory_count": index.memory_count,
+        },
+        **search_result,
+    }
+    _write_jsonl(traj, record)
+    return _render_text(record)
+
+
+def _write_jsonl(path: Path, record: dict[str, Any]) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    with path.open("a", encoding="utf-8") as f:
+        f.write(json.dumps(record, ensure_ascii=False) + "\n")
+
+
+def retrieve_hits(
+    *,
+    client: Any,
+    session_id: str,
+    question: str,
+    memory_map: dict[str, Any],
+    top_k: int,
+    chunk_top_k: int,
+) -> dict[str, Any]:
+    session = client.with_session(session_id)
+    query = f"Question: {question}"
+    query_context = QUERY_CONTEXT_PROMPT.format(question=question)
+    raw_results = session.search(query, query_context=query_context, top_k=chunk_top_k)
+    ordered_ids = _ordered_chunk_ids(raw_results, memory_map)
+    id_segments = _result_segments_by_id(raw_results, memory_map)
+    raw_segment_count = len(_result_segments(raw_results))
+    oneshot_passes = 0
+
+    if raw_segment_count > 1:
+        ordered_ids, id_segments, oneshot_passes = _rerank_ordered_ids(
+            client=client,
+            query=query,
+            query_context=query_context,
+            results=raw_results,
+            ordered_ids=ordered_ids,
+            id_segments=id_segments,
+            memory_map=memory_map,
+            top_k=chunk_top_k,
+            passes=8,
+        )
+
+    hits = _fused_hits(
+        ordered_ids=ordered_ids,
+        id_segments=id_segments,
+        memory_map=memory_map,
+        chunk_top_k=chunk_top_k,
+        file_top_k=top_k,
+    )
+    return {
+        "hits": hits,
+        "raw_result_count": len(raw_results),
+        "raw_segment_count": raw_segment_count,
+        "oneshot_passes": oneshot_passes,
+        "search_query": query,
+        "query_context": query_context,
+    }
+
+
+def _rerank_ordered_ids(
+    *,
+    client: Any,
+    query: str,
+    query_context: str,
+    results: list[Any],
+    ordered_ids: list[str],
+    id_segments: dict[str, int | None],
+    memory_map: dict[str, Any],
+    top_k: int,
+    passes: int,
+) -> tuple[list[str], dict[str, int | None], int]:
+    current = results
+    pass_count = 0
+    seen_orders: set[tuple[str | None, ...]] = set()
+    for _ in range(passes):
+        memories = _memories_from_index_order(current, memory_map)
+        if not memories:
+            return ordered_ids, id_segments, pass_count
+        order = tuple(memory.get("id") for memory in memories)
+        if order in seen_orders:
+            return ordered_ids, id_segments, pass_count
+        seen_orders.add(order)
+        non_id_count = sum(1 for memory in memories if "id" not in memory)
+        reranked = client.oneshot_search(
+            query,
+            memories,
+            system=RERANK_SYSTEM_PROMPT,
+            query_context=query_context,
+            top_k=min(len(memories), non_id_count + top_k),
+        )
+        pass_count += 1
+        reranked_ids = _ordered_chunk_ids(reranked, memory_map)
+        if reranked_ids:
+            seen_reranked = set(reranked_ids)
+            ordered_ids = reranked_ids + [memory_id for memory_id in ordered_ids if memory_id not in seen_reranked]
+        id_segments.update(_result_segments_by_id(reranked, memory_map))
+        if len(_result_segments(reranked)) <= 1:
+            return ordered_ids, id_segments, pass_count
+        current = reranked
+    return ordered_ids, id_segments, pass_count
+
+
+def _memories_from_index_order(results: list[Any], memory_map: dict[str, Any]) -> list[dict[str, str]]:
+    text_by_id: dict[str, str] = {}
+    for result in results:
+        memory_id = getattr(result, "id", None)
+        text = getattr(result, "text", "") or ""
+        if isinstance(memory_id, str) and memory_id in memory_map and text and memory_id not in text_by_id:
+            text_by_id[memory_id] = text
+
+    memories: list[dict[str, str]] = []
+    current_file: str | None = None
+    for memory_id, location in memory_map.items():
+        text = text_by_id.get(memory_id)
+        if text is None:
+            continue
+        if location.file != current_file:
+            memories.append({"text": f"{FILE_HEADER_PREFIX}{location.file}"})
+            current_file = location.file
+        memories.append({"id": memory_id, "text": text})
+    return memories
+
+
+def _ordered_chunk_ids(results: list[Any], memory_map: dict[str, Any]) -> list[str]:
+    ordered_ids: list[str] = []
+    seen_ids: set[str] = set()
+    for result in results:
+        memory_id = getattr(result, "id", None)
+        if not isinstance(memory_id, str) or memory_id not in memory_map or memory_id in seen_ids:
+            continue
+        seen_ids.add(memory_id)
+        ordered_ids.append(memory_id)
+    return ordered_ids
+
+
+def _result_segments(results: list[Any]) -> set[int]:
+    return {
+        segment_id
+        for result in results
+        if isinstance((segment_id := getattr(result, "segment_id", None)), int)
+    }
+
+
+def _result_segments_by_id(results: list[Any], memory_map: dict[str, Any]) -> dict[str, int | None]:
+    id_segments: dict[str, int | None] = {}
+    for result in results:
+        memory_id = getattr(result, "id", None)
+        if not isinstance(memory_id, str) or memory_id not in memory_map or memory_id in id_segments:
+            continue
+        id_segments[memory_id] = getattr(result, "segment_id", None)
+    return id_segments
+
+
+def _fused_hits(
+    *,
+    ordered_ids: list[str],
+    id_segments: dict[str, int | None],
+    memory_map: dict[str, Any],
+    chunk_top_k: int,
+    file_top_k: int,
+) -> list[dict[str, Any]]:
+    chunk_hits: list[dict[str, Any]] = []
+    seen_ids: set[str] = set()
+    for memory_id in ordered_ids:
+        if memory_id not in memory_map or memory_id in seen_ids:
+            continue
+        seen_ids.add(memory_id)
+        location = memory_map[memory_id]
+        chunk_hits.append(
+            {
+                "path": location.file,
+                "start_line": location.start_line,
+                "end_line": location.end_line,
+                "chunk_rank": len(chunk_hits) + 1,
+                "memory_id": memory_id,
+                "segment_id": id_segments.get(memory_id),
+            }
+        )
+        if len(chunk_hits) >= chunk_top_k:
+            break
+
+    file_scores: dict[str, float] = {}
+    first_rank: dict[str, int] = {}
+    chunks_by_file: dict[str, list[dict[str, Any]]] = {}
+    for chunk in chunk_hits:
+        path = chunk["path"]
+        rank = chunk["chunk_rank"]
+        file_scores[path] = file_scores.get(path, 0.0) + 1.0 / math.log2(rank + 1)
+        first_rank.setdefault(path, rank)
+        chunks_by_file.setdefault(path, []).append(chunk)
+
+    ranked_paths = sorted(file_scores, key=lambda path: (-file_scores[path], first_rank[path], path))
+    hits: list[dict[str, Any]] = []
+    for file_rank, path in enumerate(ranked_paths[:file_top_k], 1):
+        ranges = _merge_ranges(
+            (chunk["start_line"], chunk["end_line"])
+            for chunk in chunks_by_file.get(path, [])
+        )
+        hits.append({"rank": file_rank, "path": path, "ranges": ranges})
+    return hits
+
+
+def _merge_ranges(ranges: Any) -> list[dict[str, int]]:
+    ordered = sorted((int(start), int(end)) for start, end in ranges if start and end)
+    merged: list[list[int]] = []
+    for start, end in ordered:
+        if not merged or start > merged[-1][1] + 1:
+            merged.append([start, end])
+        else:
+            merged[-1][1] = max(merged[-1][1], end)
+    return [{"start_line": start, "end_line": end} for start, end in merged]
+
+
+def _render_text(record: dict[str, Any]) -> str:
+    lines: list[str] = []
+    hits = record.get("hits", [])
+    if not hits:
+        return "No relevant files found."
+    for hit in hits:
+        range_text = _format_ranges(hit.get("ranges", []))
+        if range_text:
+            lines.append(f"{hit['rank']}. {hit['path']}:{range_text}")
+        else:
+            lines.append(f"{hit['rank']}. {hit['path']}")
+    return "\n".join(lines).rstrip()
+
+
+def _format_ranges(ranges: list[dict[str, int]]) -> str:
+    parts: list[str] = []
+    for item in ranges:
+        start = item.get("start_line")
+        end = item.get("end_line")
+        if isinstance(start, int) and isinstance(end, int):
+            parts.append(str(start) if start == end else f"{start}-{end}")
+    return ",".join(parts)
