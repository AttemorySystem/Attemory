+from __future__ import annotations
+
+import argparse
+import json
+import os
+from pathlib import Path
+
+from repo_index import build_or_restore_index, make_attemory_client
+
+
+ROOT = Path(__file__).resolve().parents[1]
+WORKSPACE = ROOT.parent
+DEFAULT_BENCH_ROOT = WORKSPACE if (WORKSPACE / "Benchmark").is_dir() else WORKSPACE / "SWE-QA-Bench"
+DEFAULT_REPOS_ROOT = DEFAULT_BENCH_ROOT / "datas" / "repos"
+FALLBACK_REPOS_ROOT = DEFAULT_BENCH_ROOT / "datas"
+DEFAULT_INDEX_ROOT = DEFAULT_BENCH_ROOT / ".attemory-index"
+DEFAULT_REPOS = [
+    "astropy",
+    "conan",
+    "django",
+    "flask",
+    "matplotlib",
+    "pylint",
+    "pytest",
+    "reflex",
+    "requests",
+    "scikit-learn",
+    "sphinx",
+    "sqlfluff",
+    "streamlink",
+    "sympy",
+    "xarray",
+]
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser(description="Build or restore Attemory code indexes for SWE-QA repos.")
+    parser.add_argument("--repos-root", default=os.environ.get("REPOS_ROOT"))
+    parser.add_argument("--index-root", default=os.environ.get("ATTEMORY_INDEX_ROOT") or str(DEFAULT_INDEX_ROOT))
+    parser.add_argument("--repo", action="append", choices=DEFAULT_REPOS, help="Repository to index. Repeatable.")
+    parser.add_argument("--host", default=os.environ.get("ATTEMORY_HOST", "127.0.0.1"))
+    parser.add_argument("--port", type=int, default=int(os.environ.get("ATTEMORY_PORT", "9006")))
+    parser.add_argument("--timeout", type=float, default=float(os.environ.get("ATTEMORY_TIMEOUT", "3600")))
+    parser.add_argument("--rebuild-index", action="store_true")
+    args = parser.parse_args()
+
+    client = make_attemory_client(host=args.host, port=args.port, timeout=args.timeout)
+    for repo in args.repo or DEFAULT_REPOS:
+        repos_root = Path(args.repos_root).resolve() if args.repos_root else _default_repos_root(repo).resolve()
+        result = build_or_restore_index(
+            client=client,
+            repo_name=repo,
+            repo_root=repos_root / repo,
+            index_root=args.index_root,
+            rebuild=args.rebuild_index,
+        )
+        print(
+            json.dumps(
+                {
+                    "repo": repo,
+                    "session_id": result.session_id,
+                    "reused": result.reused,
+                    "memory_count": result.memory_count,
+                    "index_ms": result.index_ms,
+                },
+                ensure_ascii=False,
+            )
+        )
+
+
+def _default_repos_root(repo_name: str) -> Path:
+    if (DEFAULT_REPOS_ROOT / repo_name).exists():
+        return DEFAULT_REPOS_ROOT
+    if (FALLBACK_REPOS_ROOT / repo_name).exists():
+        return FALLBACK_REPOS_ROOT
+    return DEFAULT_REPOS_ROOT
+
+
+if __name__ == "__main__":
+    main()
diff --git a/attemory/scripts/claude_stream.py b/attemory/scripts/claude_stream.py
new file mode 100644
index 0000000..943bd9b
--- /dev/null
+++ b/attemory/scripts/claude_stream.py
@@ -0,0 +1,290 @@
+from __future__ import annotations
+
+import json
+import re
+from collections import Counter
+from typing import Any
+
+
+TOKEN_KEYS = {
+    "input_tokens",
+    "output_tokens",
+    "cache_creation_input_tokens",
+    "cache_read_input_tokens",
+    "prompt_tokens",
+    "completion_tokens",
+    "total_tokens",
+}
+
+
+def parse_stream_json(text: str) -> list[dict[str, Any]]:
+    events: list[dict[str, Any]] = []
+    for line in text.splitlines():
+        stripped = line.strip()
+        if not stripped:
+            continue
+        try:
+            event = json.loads(stripped)
+        except json.JSONDecodeError:
+            continue
+        if isinstance(event, dict):
+            events.append(event)
+    return events
+
+
+def extract_submission(events: list[dict[str, Any]], stdout: str) -> str:
+    final_answer = _latest_final_answer(events, stdout)
+    if final_answer:
+        return final_answer
+    result_text = _latest_result_text(events)
+    if result_text:
+        return _extract_final_answer(result_text)
+    assistant_texts = list(_assistant_texts(events))
+    if assistant_texts:
+        return _extract_final_answer(assistant_texts[-1])
+    return _extract_final_answer(stdout)
+
+
+def diagnose_submission(events: list[dict[str, Any]], stdout: str, submission: str) -> dict[str, Any]:
+    has_final_answer = bool(_latest_final_answer(events, stdout))
+    if has_final_answer or not _looks_like_procedural_submission(submission):
+        return {}
+    return {
+        "issue": "missing_final_answer_meta_output",
+        "severity": "invalid",
+        "submission_len": len(submission or ""),
+        "latest_result": _latest_result_text(events)[:300],
+    }
+
+
+def summarize_usage(events: list[dict[str, Any]]) -> dict[str, Any]:
+    result_usage = None
+    total_cost_usd = None
+    for event in events:
+        if event.get("type") == "result":
+            usage = event.get("usage")
+            if isinstance(usage, dict):
+                result_usage = usage
+            if isinstance(event.get("total_cost_usd"), int | float):
+                total_cost_usd = event["total_cost_usd"]
+    usage = _normalize_usage(result_usage) if result_usage else _sum_nested_usage(events)
+    if total_cost_usd is not None:
+        usage["total_cost_usd"] = total_cost_usd
+    return usage
+
+
+def summarize_tools(events: list[dict[str, Any]]) -> dict[str, Any]:
+    counts: Counter[str] = Counter()
+    bash_commands: list[str] = []
+    for event in events:
+        for block in _walk_content_blocks(event):
+            if block.get("type") != "tool_use":
+                continue
+            name = str(block.get("name") or "")
+            if not name:
+                continue
+            counts[name] += 1
+            if name == "Bash":
+                command = _bash_command(block)
+                if command:
+                    bash_commands.append(command)
+    attemory_calls = [cmd for cmd in bash_commands if _command_invokes(cmd, "attemory-search")]
+    return {
+        "tool_call_count": sum(counts.values()),
+        "tool_counts": dict(sorted(counts.items())),
+        "bash_call_count": counts.get("Bash", 0),
+        "attemory_search_calls": len(attemory_calls),
+        "attemory_search_commands": attemory_calls,
+        "agent_tool_calls": counts.get("Agent", 0) + counts.get("Task", 0),
+    }
+
+
+def _latest_result_text(events: list[dict[str, Any]]) -> str:
+    for event in reversed(events):
+        if event.get("type") == "result":
+            for key in ("result", "text", "content"):
+                value = event.get(key)
+                if isinstance(value, str) and value.strip():
+                    return value
+    return ""
+
+
+def _latest_final_answer(events: list[dict[str, Any]], stdout: str) -> str:
+    candidates: list[tuple[bool, str]] = []
+    for event in events:
+        parent_tool_use_id = event.get("parent_tool_use_id")
+        is_top_level = parent_tool_use_id is None
+        for text in _event_texts(event):
+            final_answer = _extract_tagged_final_answer(text)
+            if final_answer:
+                candidates.append((is_top_level, final_answer))
+    top_level = [text for is_top_level, text in candidates if is_top_level]
+    if top_level:
+        return top_level[-1]
+    if candidates:
+        return candidates[-1][1]
+    return _extract_tagged_final_answer(stdout)
+
+
+def _event_texts(event: dict[str, Any]):
+    if event.get("type") == "result":
+        for key in ("result", "text", "content"):
+            value = event.get(key)
+            if isinstance(value, str) and value.strip():
+                yield value
+    message = event.get("message")
+    if not isinstance(message, dict) or message.get("role") != "assistant":
+        return
+    content = message.get("content")
+    if isinstance(content, str):
+        yield content
+    elif isinstance(content, list):
+        texts = [
+            item.get("text")
+            for item in content
+            if isinstance(item, dict) and item.get("type") == "text" and isinstance(item.get("text"), str)
+        ]
+        if texts:
+            yield "\n".join(texts)
+
+
+def _assistant_texts(events: list[dict[str, Any]]):
+    for event in events:
+        message = event.get("message")
+        if not isinstance(message, dict):
+            continue
+        if message.get("role") != "assistant":
+            continue
+        texts = []
+        content = message.get("content")
+        if isinstance(content, str):
+            texts.append(content)
+        elif isinstance(content, list):
+            for item in content:
+                if isinstance(item, dict) and item.get("type") == "text":
+                    text = item.get("text")
+                    if isinstance(text, str):
+                        texts.append(text)
+        if texts:
+            yield "\n".join(texts)
+
+
+def _extract_final_answer(text: str) -> str:
+    tagged = _extract_tagged_final_answer(text)
+    if tagged:
+        return tagged
+    return text.strip()
+
+
+def _extract_tagged_final_answer(text: str) -> str:
+    match = re.search(r"<final_answer>(.*?)</final_answer>", text, flags=re.DOTALL | re.IGNORECASE)
+    if match:
+        return match.group(1).strip()
+    return ""
+
+
+def _looks_like_procedural_submission(text: str) -> bool:
+    normalized = " ".join((text or "").strip().lower().split())
+    if not normalized:
+        return True
+    if len(normalized) > 800:
+        return False
+    prefixes = (
+        "now let me",
+        "now i have",
+        "let me ",
+        "i need to ",
+        "i should ",
+        "i will ",
+        "i'll ",
+        "the background agent",
+        "the agent is ",
+        "i have all the evidence",
+    )
+    substrings = (
+        "compose the final answer",
+        "formulate the final answer",
+        "write the final answer",
+        "look at the ",
+        "completed and confirms the analysis",
+        "final answer i provided above",
+    )
+    return normalized.startswith(prefixes) or any(item in normalized for item in substrings)
+
+
+def _sum_nested_usage(events: list[dict[str, Any]]) -> dict[str, int]:
+    total: dict[str, int] = {}
+    for event in events:
+        for usage in _walk_usage_dicts(event):
+            normalized = _normalize_usage(usage)
+            for key, value in normalized.items():
+                if isinstance(value, int):
+                    total[key] = total.get(key, 0) + value
+    total["total_reported_tokens"] = _reported_total(total)
+    return total
+
+
+def _normalize_usage(usage: dict[str, Any]) -> dict[str, Any]:
+    normalized: dict[str, Any] = {}
+    for key, value in usage.items():
+        if key in TOKEN_KEYS and isinstance(value, int | float):
+            normalized[key] = int(value)
+    if "input_tokens" not in normalized and "prompt_tokens" in normalized:
+        normalized["input_tokens"] = normalized["prompt_tokens"]
+    if "output_tokens" not in normalized and "completion_tokens" in normalized:
+        normalized["output_tokens"] = normalized["completion_tokens"]
+    normalized["total_reported_tokens"] = _reported_total(normalized)
+    return normalized
+
+
+def _reported_total(usage: dict[str, Any]) -> int:
+    if isinstance(usage.get("total_tokens"), int):
+        return int(usage["total_tokens"])
+    return sum(
+        int(usage.get(key, 0) or 0)
+        for key in (
+            "input_tokens",
+            "output_tokens",
+            "cache_creation_input_tokens",
+            "cache_read_input_tokens",
+        )
+    )
+
+
+def _walk_usage_dicts(value: Any):
+    if isinstance(value, dict):
+        usage = value.get("usage")
+        if isinstance(usage, dict):
+            yield usage
+        for item in value.values():
+            yield from _walk_usage_dicts(item)
+    elif isinstance(value, list):
+        for item in value:
+            yield from _walk_usage_dicts(item)
+
+
+def _walk_content_blocks(value: Any):
+    if isinstance(value, dict):
+        content = value.get("content")
+        if isinstance(content, list):
+            for item in content:
+                if isinstance(item, dict):
+                    yield item
+        for item in value.values():
+            yield from _walk_content_blocks(item)
+    elif isinstance(value, list):
+        for item in value:
+            yield from _walk_content_blocks(item)
+
+
+def _bash_command(block: dict[str, Any]) -> str:
+    tool_input = block.get("input")
+    if isinstance(tool_input, dict):
+        command = tool_input.get("command")
+        if isinstance(command, str):
+            return command
+    return ""
+
+
+def _command_invokes(command: str, executable: str) -> bool:
+    return re.search(rf"(^|[;&|()\s]){re.escape(executable)}(\s|$)", command) is not None
