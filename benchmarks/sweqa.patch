+import argparse
+import csv
+import json
+from pathlib import Path
+
+
+FIELDS = [
+    "sample_id",
+    "main_tokens",
+    "subagent_tokens",
+    "total_tokens",
+    "main_turns",
+    "subagent_turns",
+    "subagent_calls",
+]
+
+
+def read_jsonl(path):
+    rows = []
+    for line in path.read_text(encoding="utf-8", errors="ignore").splitlines():
+        try:
+            obj = json.loads(line)
+        except json.JSONDecodeError:
+            continue
+        if isinstance(obj, dict):
+            rows.append(obj)
+    return rows
+
+
+def token_sum(data, keys):
+    return sum(int(data.get(key, 0) or 0) for key in keys if isinstance(data.get(key, 0), int | float))
+
+
+def latest_result(events):
+    for event in reversed(events):
+        if event.get("type") == "result":
+            return event
+    return {}
+
+
+def result_tokens(result):
+    usage = result.get("usage") if isinstance(result.get("usage"), dict) else {}
+    if isinstance(usage.get("total_tokens"), int):
+        return usage["total_tokens"]
+    return token_sum(usage, ["input_tokens", "output_tokens", "cache_creation_input_tokens", "cache_read_input_tokens"])
+
+
+def sample_id(sample_dir):
+    path = sample_dir / "sample.json"
+    if path.exists():
+        try:
+            value = json.loads(path.read_text(encoding="utf-8")).get("sample_id")
+        except json.JSONDecodeError:
+            value = None
+        if value:
+            return value
+    return sample_dir.name
+
+
+def sample_dirs(run_dir):
+    samples_txt = run_dir / "samples.txt"
+    if samples_txt.exists():
+        names = [line.strip() for line in samples_txt.read_text(encoding="utf-8").splitlines() if line.strip()]
+        return [run_dir / name for name in names if (run_dir / name / "claude_stream.jsonl").exists()]
+    return sorted(path for path in run_dir.iterdir() if (path / "claude_stream.jsonl").exists())
+
+
+def assistant_message(event):
+    message = event.get("message")
+    if isinstance(message, dict) and message.get("role") == "assistant":
+        return message
+    return None
+
+
+def subagent_tool_ids(events):
+    ids = {
+        event.get("tool_use_id") or event.get("task_id")
+        for event in events
+        if event.get("type") == "system" and event.get("subtype") == "task_started"
+    }
+    ids.discard(None)
+    if ids:
+        return ids
+
+    # Older Claude Code logs may not have task_started events, so fall back to
+    # top-level Agent/Task tool_use blocks.
+    for event in events:
+        if event.get("parent_tool_use_id"):
+            continue
+        message = assistant_message(event)
+        if not message or not isinstance(message.get("content"), list):
+            continue
+        for block in message["content"]:
+            if isinstance(block, dict) and block.get("type") == "tool_use" and block.get("name") in {"Agent", "Task"}:
+                ids.add(block.get("id"))
+    ids.discard(None)
+    return ids
+
+
+def subagent_tokens(events, tool_ids):
+    # Parent-marked assistant messages are the subagent's intermediate model
+    # calls. Deduplicate by message id because one message can be streamed as
+    # separate thinking/tool_use chunks with the same usage.
+    parent_usage = {}
+    for event in events:
+        parent = event.get("parent_tool_use_id")
+        message = assistant_message(event)
+        if parent not in tool_ids or not message:
+            continue
+        usage = message.get("usage")
+        if isinstance(usage, dict):
+            parent_usage[(parent, message.get("id"))] = token_sum(
+                usage,
+                ["input_tokens", "output_tokens", "cache_creation_input_tokens", "cache_read_input_tokens"],
+            )
+
+    # The final Agent/Task result is reported on the top-level tool_result.
+    final_usage = 0
+    for event in events:
+        message = event.get("message")
+        if not isinstance(message, dict) or not isinstance(message.get("content"), list):
+            continue
+        result_ids = {
+            block.get("tool_use_id")
+            for block in message["content"]
+            if isinstance(block, dict) and block.get("type") == "tool_result"
+        }
+        if not result_ids.intersection(tool_ids):
+            continue
+        tool_result = event.get("tool_use_result")
+        if isinstance(tool_result, dict):
+            final_usage += int(tool_result.get("totalTokens") or 0)
+
+    return sum(parent_usage.values()) + final_usage
+
+
+def summarize(sample_dir):
+    events = read_jsonl(sample_dir / "claude_stream.jsonl")
+    result = latest_result(events)
+    tool_ids = subagent_tool_ids(events)
+    main_tokens = result_tokens(result)
+    sub_tokens = subagent_tokens(events, tool_ids)
+
+    main_turns = int(result.get("num_turns") or 0)
+    if not main_turns:
+        main_turns = len(
+            {
+                assistant_message(event).get("id")
+                for event in events
+                if assistant_message(event) and not event.get("parent_tool_use_id")
+            }
+        )
+    sub_turns = len(
+        {
+            assistant_message(event).get("id")
+            for event in events
+            if assistant_message(event) and event.get("parent_tool_use_id")
+        }
+    )
+
+    return {
+        "sample_id": sample_id(sample_dir),
+        "main_tokens": main_tokens,
+        "subagent_tokens": sub_tokens,
+        "total_tokens": main_tokens + sub_tokens,
+        "main_turns": main_turns,
+        "subagent_turns": sub_turns,
+        "subagent_calls": len(tool_ids),
+    }
+
+
+def fmt(num):
+    if num >= 1_000_000:
+        return f"{num / 1_000_000:.2f}M"
+    if num >= 1_000:
+        return f"{num / 1_000:.1f}k"
+    return str(num)
+
+
+def main():
+    parser = argparse.ArgumentParser()
+    parser.add_argument("run_dir", help="Example: logs/attemory_requests")
+    parser.add_argument("--csv", help="Optional CSV output path")
+    args = parser.parse_args()
+
+    rows = [summarize(path) for path in sample_dirs(Path(args.run_dir))]
+    totals = {key: sum(int(row[key]) for row in rows) for key in FIELDS if key != "sample_id"}
+
+    print(f"run_dir: {args.run_dir}")
+    print(f"samples: {len(rows)}")
+    print(
+        "tokens: "
+        f"main={fmt(totals['main_tokens'])} "
+        f"subagent={fmt(totals['subagent_tokens'])} "
+        f"total={fmt(totals['total_tokens'])}"
+    )
+    print(
+        "turns: "
+        f"main={fmt(totals['main_turns'])} "
+        f"subagent={fmt(totals['subagent_turns'])} "
+        f"subagent_calls={fmt(totals['subagent_calls'])}"
+    )
+    print("\n" + ",".join(FIELDS))
+    for row in rows:
+        print(",".join(str(row[key]) for key in FIELDS))
+
+    if args.csv:
+        with Path(args.csv).open("w", encoding="utf-8", newline="") as f:
+            writer = csv.DictWriter(f, fieldnames=FIELDS)
+            writer.writeheader()
+            writer.writerows(rows)
+
+
+if __name__ == "__main__":
+    main()
