new file mode 100644
index 0000000..6f3190b
--- /dev/null
+++ b/attemory/scripts/judge.py
@@ -0,0 +1,128 @@
+import argparse
+import json
+import os
+import subprocess
+import sys
+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parents[1]
+BENCH_ROOT = ROOT.parent
+JUDGE_SCRIPT = BENCH_ROOT / "Benchmark construction" / "score" / "llm-as-a-judge.py"
+
+
+def main():
+    parser = argparse.ArgumentParser(description="Run the official SWE-QA judge for default and Attemory outputs.")
+    parser.add_argument("repo", help="Repo name, for example requests or scikit-learn")
+    parser.add_argument("--workers", default=os.environ.get("EVAL_MAX_WORKERS", "2"))
+    parser.add_argument("--model", default=os.environ.get("EVAL_LLM_MODEL_NAME", "openai/gpt-5.4"))
+    parser.add_argument("--output-dir", default=str(ROOT / "output"))
+    parser.add_argument("--api-key", default="", help="OpenRouter API key. Prefer env var for normal use.")
+    args = parser.parse_args()
+
+    output_dir = Path(args.output_dir)
+    repo_path_name = args.repo.replace("-", "_")
+    reference = BENCH_ROOT / "Benchmark" / f"{args.repo}.jsonl"
+
+    if not reference.exists():
+        raise SystemExit(f"missing reference file: {reference}")
+    if not JUDGE_SCRIPT.exists():
+        raise SystemExit(f"missing official judge script: {JUDGE_SCRIPT}")
+
+    results = []
+    for backend in ("default", "attemory"):
+        candidate = output_dir / f"{backend}_{repo_path_name}.jsonl"
+        score_path = output_dir / f"{backend}_{repo_path_name}_score.jsonl"
+        if not candidate.exists():
+            raise SystemExit(f"missing candidate file: {candidate}")
+
+        run_judge(
+            candidate=candidate,
+            reference=reference,
+            output=score_path,
+            model=args.model,
+            workers=args.workers,
+            api_key=args.api_key,
+        )
+        results.append((backend, score_path, summarize_scores(score_path)))
+
+    print("\nsummary")
+    print("backend,samples,avg_score,total_score,score_file")
+    for backend, score_path, summary in results:
+        print(
+            f"{backend},"
+            f"{summary['samples']},"
+            f"{summary['avg_score']:.2f},"
+            f"{summary['total_score']},"
+            f"{score_path}"
+        )
+
+
+def run_judge(candidate, reference, output, model, workers, api_key):
+    env = os.environ.copy()
+    env["EVAL_LLM_PROVIDER"] = "openrouter"
+    env["EVAL_LLM_BASE_URL"] = env.get("EVAL_LLM_BASE_URL") or "https://openrouter.ai/api/v1"
+    env["EVAL_LLM_MODEL_NAME"] = model
+    env["EVAL_MAX_WORKERS"] = str(workers)
+    env["EVAL_REFERENCE_PATH"] = str(reference)
+    env["EVAL_CANDIDATE_PATH"] = str(candidate)
+    env["EVAL_OUTPUT_PATH"] = str(output)
+
+    key, source = first_value(
+        (api_key, "--api-key"),
+        (env.get("EVAL_LLM_API_KEY"), "EVAL_LLM_API_KEY"),
+        (env.get("OPENROUTER_API_KEY"), "OPENROUTER_API_KEY"),
+        (env.get("OPENAI_API_KEY"), "OPENAI_API_KEY"),
+    )
+    if not key:
+        raise SystemExit("missing API key: set EVAL_LLM_API_KEY or OPENROUTER_API_KEY")
+    if key.startswith("<") or key.endswith(">"):
+        raise SystemExit("API key still looks like a placeholder; set a real OpenRouter key")
+    env["EVAL_LLM_API_KEY"] = key
+    env["OPENAI_API_KEY"] = key
+
+    print(f"\n=== judge {candidate.name} ===", flush=True)
+    print(
+        f"judge auth: {source} -> EVAL_LLM_API_KEY={redact_key(key)} "
+        f"base_url={env['EVAL_LLM_BASE_URL']} model={env['EVAL_LLM_MODEL_NAME']}",
+        flush=True,
+    )
+    subprocess.run([sys.executable, str(JUDGE_SCRIPT)], cwd=BENCH_ROOT, env=env, check=True)
+
+
+def first_value(*pairs):
+    for value, source in pairs:
+        if value is None:
+            continue
+        value = str(value).strip()
+        if value:
+            return value, source
+    return "", ""
+
+
+def redact_key(key):
+    if len(key) <= 8:
+        return "***"
+    return f"{key[:6]}...{key[-4:]}"
+
+
+def summarize_scores(path):
+    samples = 0
+    total_score = 0
+    with path.open(encoding="utf-8") as f:
+        for line in f:
+            if not line.strip():
+                continue
+            record = json.loads(line)
+            score = record.get("score")
+            if not isinstance(score, dict):
+                continue
+            samples += 1
+            total_score += int(record.get("total_score") or sum(int(value) for value in score.values()))
+
+    avg_score = total_score / samples if samples else 0.0
+    return {"samples": samples, "total_score": total_score, "avg_score": avg_score}
+
+
+if __name__ == "__main__":
+    main()
