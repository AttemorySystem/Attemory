+#!/usr/bin/env python3
+from __future__ import annotations
+
+import argparse
+import concurrent.futures
+import json
+import os
+import subprocess
+import uuid
+from pathlib import Path
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parents[1]
+SCRIPT_DIR = Path(__file__).resolve().parent
+WORKSPACE = ROOT.parent
+DEFAULT_BENCH_ROOT = WORKSPACE if (WORKSPACE / "Benchmark").is_dir() else WORKSPACE / "SWE-QA-Bench"
+DEFAULT_REPOS_ROOT = DEFAULT_BENCH_ROOT / "datas" / "repos"
+FALLBACK_REPOS_ROOT = DEFAULT_BENCH_ROOT / "datas"
+DEFAULT_TOOLS = "Task,Bash,Read,Grep,Glob"
+DEFAULT_ALLOWED_TOOLS = (
+    "Task,Read,Grep,Glob,Bash(pwd:*),Bash(ls:*),Bash(find:*),Bash(rg:*),Bash(grep:*),"
+    "Bash(sed:*),Bash(cat:*),Bash(head:*),Bash(tail:*),Bash(wc:*),Bash(awk:*),"
+    "Bash(cut:*),Bash(sort:*),Bash(uniq:*)"
+)
+DEFAULT_DISALLOWED_TOOLS = "Edit,Write,WebFetch,WebSearch"
+FALSE_VALUES = {"0", "false", "no", "off"}
+
+from claude_stream import diagnose_submission, extract_submission, parse_stream_json, summarize_tools, summarize_usage
+from make_readable_prompts import prepare_prompts
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser(description="SWE-QA runner for Claude Code.")
+    parser.add_argument("backend", choices=["default", "attemory"])
+    parser.add_argument("repo")
+    parser.add_argument("--workers", "--worker", type=int, default=int(os.environ.get("WORKERS", "1")))
+    parser.add_argument("--sample-id", action="append")
+    args = parser.parse_args()
+
+    python_paths = [str(SCRIPT_DIR), str(ROOT)]
+    attemory_root = os.environ.get("ATTEMORY_ROOT") or _infer_attemory_root()
+    if attemory_root:
+        python_paths.append(str(Path(attemory_root) / "python"))
+    if os.environ.get("PYTHONPATH"):
+        python_paths.append(os.environ["PYTHONPATH"])
+    os.environ["PYTHONPATH"] = ":".join(python_paths)
+
+    run_name = f"{args.backend}_{_path_name(args.repo)}"
+    run_dir = Path(os.environ.get("RUN_DIR", str(ROOT / "logs" / run_name)))
+    output = Path(os.environ.get("OUTPUT", str(ROOT / "output" / f"{run_name}.jsonl")))
+    repos_root = Path(os.environ["REPOS_ROOT"]) if os.environ.get("REPOS_ROOT") else _default_repos_root(args.repo)
+    repo_root = repos_root / args.repo
+
+    prepare_prompts(backend=args.backend, repo=args.repo, run_dir=run_dir, sample_ids=_split_sample_ids(args.sample_id))
+
+    sample_ids = [line for line in (run_dir / "samples.txt").read_text(encoding="utf-8").splitlines() if line]
+    if args.workers <= 1:
+        for sample_id in sample_ids:
+            run_one_sample(repo_root, run_dir, sample_id)
+    else:
+        with concurrent.futures.ThreadPoolExecutor(max_workers=args.workers) as executor:
+            futures = {
+                executor.submit(run_one_sample, repo_root, run_dir, sample_id): sample_id
+                for sample_id in sample_ids
+            }
+            for future in concurrent.futures.as_completed(futures):
+                future.result()
+
+    collect_run(args.backend, run_dir, output)
+    print(f"wrote {output}")
+
+
+def run_one_sample(repo_root: Path, run_dir: Path, sample_id: str) -> None:
+    sample_dir = run_dir / sample_id
+    print(f"=== {sample_id} ===", flush=True)
+    result = run_claude(
+        repo_root,
+        sample_dir / "prompt.txt",
+        sample_dir / "claude_stream.jsonl",
+        sample_dir / "claude_stderr.log",
+    )
+    (sample_dir / "exit_code").write_text(f"{result.returncode}\n", encoding="utf-8")
+    print_sample_summary(sample_id, result.returncode, sample_dir / "claude_stream.jsonl")
+
+
+def run_claude(repo_root: Path, prompt_path: Path, stdout_path: Path, stderr_path: Path) -> subprocess.CompletedProcess:
+    tools = os.environ.get("CLAUDE_TOOLS") or DEFAULT_TOOLS
+    allowed_tools = os.environ.get("ALLOWED_TOOLS") or DEFAULT_ALLOWED_TOOLS
+    disallowed_tools = os.environ.get("DISALLOWED_TOOLS") or DEFAULT_DISALLOWED_TOOLS
+    env = os.environ.copy()
+    _isolate_claude_home(env, stdout_path.parent)
+    command: list[Any] = [
+        os.environ.get("CLAUDE_BIN") or "claude",
+        "-p",
+        prompt_path.read_text(encoding="utf-8"),
+        "--output-format",
+        "stream-json",
+        "--verbose",
+        "--no-session-persistence",
+        "--permission-mode",
+        os.environ.get("PERMISSION_MODE", "dontAsk"),
+        "--tools",
+        tools,
+        "--allowed-tools",
+        allowed_tools,
+        "--disallowed-tools",
+        disallowed_tools,
+    ]
+    model = os.environ.get("CLAUDE_MODEL") or os.environ.get("MODEL")
+    if model:
+        command += ["--model", model]
+
+    completed = subprocess.run(
+        [str(arg) for arg in command],
+        cwd=repo_root,
+        env=env,
+        text=True,
+        capture_output=True,
+    )
+    stdout_path.write_text(completed.stdout or "", encoding="utf-8")
+    stderr_path.write_text(completed.stderr or "", encoding="utf-8")
+    return completed
+
+
+def collect_run(backend: str, run_dir: Path, output: Path) -> None:
+    output.parent.mkdir(parents=True, exist_ok=True)
+    with output.open("w", encoding="utf-8") as f:
+        for sample_id in (run_dir / "samples.txt").read_text(encoding="utf-8").splitlines():
+            if sample_id:
+                f.write(json.dumps(_collect_one(backend, run_dir / sample_id), ensure_ascii=False) + "\n")
+
+
+def _collect_one(backend: str, sample_dir: Path) -> dict[str, Any]:
+    sample = json.loads((sample_dir / "sample.json").read_text(encoding="utf-8"))
+    stdout = (sample_dir / "claude_stream.jsonl").read_text(encoding="utf-8", errors="ignore")
+    stderr_path = sample_dir / "claude_stderr.log"
+    stderr = stderr_path.read_text(encoding="utf-8", errors="ignore") if stderr_path.exists() else ""
+    events = parse_stream_json(stdout)
+    submission = extract_submission(events, stdout)
+    exit_code_path = sample_dir / "exit_code"
+    exit_code = int(exit_code_path.read_text(encoding="utf-8").strip() or "0") if exit_code_path.exists() else 0
+
+    record = {
+        "sample_id": sample["sample_id"],
+        "repo": sample["repo"],
+        "question": sample["question"],
+        "reference_answer": sample["reference_answer"],
+        "submission": submission,
+        "answer": submission,
+        "backend": f"cc_{backend}",
+        "exit_status": "success" if exit_code == 0 else f"returncode_{exit_code}",
+        "usage": summarize_usage(events),
+        "tool_stats": summarize_tools(events),
+        "paths": {
+            "prompt": str((sample_dir / "prompt.txt").resolve()),
+            "claude_stream": str((sample_dir / "claude_stream.jsonl").resolve()),
+            "claude_stderr": str(stderr_path.resolve()),
+            "attemory_traj": str((sample_dir / "attemory_search.jsonl").resolve()) if backend == "attemory" else None,
+        },
+        "raw": sample["raw"],
+    }
+    submission_issue = diagnose_submission(events, stdout, submission)
+    if submission_issue:
+        record["submission_issue"] = submission_issue
+    if backend == "attemory":
+        traj = sample_dir / "attemory_search.jsonl"
+        if traj.exists() and traj.read_text(encoding="utf-8").strip():
+            record["attemory_presearch"] = json.loads(traj.read_text(encoding="utf-8").splitlines()[-1])
+    if exit_code != 0:
+        record["stderr_tail"] = stderr[-4000:]
+    return record
+
+
+def print_sample_summary(sample_id: str, returncode: int, stream_path: Path) -> None:
+    events = parse_stream_json(stream_path.read_text(encoding="utf-8", errors="ignore"))
+    usage = summarize_usage(events)
+    tools = summarize_tools(events)
+    print(
+        f"{sample_id} returncode={returncode} "
+        f"tokens={usage.get('total_reported_tokens', 0)} "
+        f"input={usage.get('input_tokens', 0)} "
+        f"cached={usage.get('cache_read_input_tokens', 0)} "
+        f"output={usage.get('output_tokens', 0)} "
+        f"cost={usage.get('total_cost_usd', 0)} "
+        f"tools={tools.get('tool_call_count', 0)}",
+        flush=True,
+    )
+
+
+def _split_sample_ids(values: list[str] | None) -> list[str] | None:
+    if not values:
+        return None
+    sample_ids = [item.strip() for value in values for item in value.split(",") if item.strip()]
+    return sample_ids or None
+
+
+def _path_name(value: str) -> str:
+    return value.replace("-", "_")
+
+
+def _default_repos_root(repo_name: str) -> Path:
+    if (DEFAULT_REPOS_ROOT / repo_name).exists():
+        return DEFAULT_REPOS_ROOT
+    if (FALLBACK_REPOS_ROOT / repo_name).exists():
+        return FALLBACK_REPOS_ROOT
+    return DEFAULT_REPOS_ROOT
+
+
+def _isolate_claude_home(env: dict[str, str], sample_dir: Path) -> None:
+    if env.get("CLAUDE_ISOLATE_HOME", "1").lower() in FALSE_VALUES:
+        return
+    home = sample_dir / ".claude_home" / uuid.uuid4().hex
+    home.mkdir(parents=True, exist_ok=True)
+    env["HOME"] = str(home)
+
+
+def _infer_attemory_root() -> str | None:
+    for parent in Path(__file__).resolve().parents:
+        if (parent / "python" / "attemory").is_dir():
+            return str(parent)
+    return None
+
+
+if __name__ == "__main__":
+    main()
